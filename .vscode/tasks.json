{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Project",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/.vscode/setup.py",
         "${userHome}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": [],
       "runOptions": { "runOn": "folderOpen" }
    }
  ]
}